<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <context-param>
        <param-name>username</param-name>
        <param-value>zyz</param-value>
    </context-param>

    <context-param>
        <param-name>password</param-name>
        <param-value>12345</param-value>
    </context-param>


    <!--servlet1-->
    <servlet>
    <servlet-name>servlet1</servlet-name>
    <servlet-class>com.zyz.testServlet.Servlet1</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>servlet1</servlet-name>
        <url-pattern>/servlet1</url-pattern>
    </servlet-mapping>


    <!--servlet2-->
    <servlet>
        <servlet-name>servlet2</servlet-name>
        <servlet-class>com.zyz.testServlet.Servlet2</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>servlet2</servlet-name>
        <url-pattern>/servlet2</url-pattern>
    </servlet-mapping>



    <!--servlet3-->
    <servlet>
        <servlet-name>servlet3</servlet-name>
        <servlet-class>com.zyz.testServlet.Servlet3</servlet-class>
        <init-param>
            <param-name>brand</param-name>
            <param-value>ASUS</param-value>
        </init-param>
        <init-param>
            <param-name>screen</param-name>
            <param-value>三星</param-value>
        </init-param>
    </servlet>

    <servlet-mapping>
        <servlet-name>servlet3</servlet-name>
        <url-pattern>/servlet3</url-pattern>
    </servlet-mapping>


    <!--servlet4-->
    <servlet>
        <servlet-name>servlet4</servlet-name>
        <servlet-class>com.zyz.testServlet.Servlet4</servlet-class>
        <init-param>
            <param-name>品牌</param-name>
            <param-value>联想</param-value>
        </init-param>
        <init-param>
            <param-name>屏幕</param-name>
            <param-value>京东方</param-value>
        </init-param>
    </servlet>

    <servlet-mapping>
        <servlet-name>servlet4</servlet-name>
        <url-pattern>/servlet4</url-pattern>
    </servlet-mapping>

</web-app>